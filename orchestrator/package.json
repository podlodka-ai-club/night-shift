{
  "name": "orchestrator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc --build",
    "build.watch": "tsc --build --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "smoke:all": "npm run smoke:claude && npm run smoke:codex && npm run smoke:output-schema && npm run smoke:tools",
    "smoke:claude": "ts-node --transpile-only scripts/smoke-claude-agent.ts",
    "smoke:codex": "ts-node --transpile-only scripts/smoke-codex.ts",
    "smoke:output-schema": "ts-node --transpile-only scripts/smoke-output-schema.ts",
    "smoke:tools": "ts-node --transpile-only scripts/smoke-tools.ts",
    "start": "ts-node src/worker.ts",
    "start.watch": "nodemon src/worker.ts",
    "workflow": "ts-node src/client.ts",
    "eval:implement": "ts-node src/cli/eval-implement.ts",
    "eval:specify": "ts-node src/cli/eval-specify.ts",
    "test": "mocha --exit --require ts-node/register --require source-map-support/register src/mocha/*.test.ts"
  },
  "nodemonConfig": {
    "execMap": {
      "ts": "ts-node"
    },
    "ext": "ts",
    "watch": [
      "src"
    ]
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.126",
    "@openai/codex-sdk": "^0.125.0",
    "@temporalio/activity": "^1.16.1",
    "@temporalio/client": "^1.16.0",
    "@temporalio/envconfig": "^1.16.0",
    "@temporalio/worker": "^1.16.0",
    "@temporalio/workflow": "^1.16.0",
    "execa": "^9.6.1",
    "nanoid": "3.x",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@temporalio/testing": "^1.16.0",
    "@tsconfig/node22": "^22.0.0",
    "@types/mocha": "8.x",
    "@types/node": "^22.9.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-deprecation": "^3.0.0",
    "mocha": "8.x",
    "nodemon": "^3.1.7",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
