{
  "name": "night-shift",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Turn tickets into reviewable PRs with measurable quality, cost, and latency.",
  "engines": {
    "node": ">=22.9"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:contracts": "node scripts/check-contracts-imports.mjs",
    "lint:boundaries": "node scripts/check-boundaries.mjs",
    "specify": "node --env-file-if-exists=.env --import tsx src/cli/specify.ts",
    "implement": "node --env-file-if-exists=.env --import tsx src/cli/implement.ts",
    "review": "node --env-file-if-exists=.env --import tsx src/cli/review.ts",
    "worker": "node --env-file-if-exists=.env --import tsx src/cli/worker.ts",
    "worker:restart-clean": "node scripts/restart-worker-clean.mjs",
    "temporal:restart-clean": "node scripts/restart-temporal-clean.mjs",
    "start": "node --env-file-if-exists=.env --import tsx src/cli/start.ts",
    "pickup": "node --env-file=.env --import tsx src/cli/pickup.ts"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.2.0",
    "@octokit/core": "^7.0.6",
    "@octokit/graphql": "^9.0.3",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks": "^14.2.0",
    "@openai/codex-sdk": "^0.124.0",
    "@temporalio/activity": "^1.11.0",
    "@temporalio/client": "^1.11.0",
    "@temporalio/worker": "^1.11.0",
    "@temporalio/workflow": "^1.11.0",
    "simple-git": "^3.36.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@temporalio/testing": "^1.16.1",
    "@types/node": "^20.14.0",
    "nock": "^14.0.13",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
